{
  "name": "frontend",
  "private": true,
  "version": "2.0.0",
  "packageManager": "pnpm@10.12.4",
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "predev": "node ./scripts/require-pnpm.mjs",
    "dev": "vite dev --port 3000",
    "prebuild": "node ./scripts/require-pnpm.mjs",
    "build": "pnpm run typecheck && vite build",
    "pretypecheck": "node ./scripts/require-pnpm.mjs",
    "typecheck": "tsc --noEmit",
    "preformat": "node ./scripts/require-pnpm.mjs",
    "format": "prettier --write . --ignore-path ../.prettierignore",
    "preformat:check": "node ./scripts/require-pnpm.mjs",
    "format:check": "prettier --check . --ignore-path ../.prettierignore",
    "prelint": "node ./scripts/require-pnpm.mjs",
    "lint": "eslint .",
    "prepreview": "node ./scripts/require-pnpm.mjs",
    "preview": "vite preview",
    "prebuild:workers": "node ./scripts/require-pnpm.mjs",
    "build:workers": "pnpm run build",
    "predeploy:workers": "node ./scripts/require-pnpm.mjs",
    "deploy:workers": "pnpm dlx wrangler deploy",
    "predeploy:workers:preview": "node ./scripts/require-pnpm.mjs",
    "deploy:workers:preview": "pnpm dlx wrangler versions upload",
    "pretest": "node ./scripts/require-pnpm.mjs",
    "test": "pnpm run test:unit && pnpm run test:integration && pnpm run test:web",
    "pretest:unit": "node ./scripts/require-pnpm.mjs",
    "test:unit": "vitest run --project unit",
    "pretest:integration": "node ./scripts/require-pnpm.mjs",
    "test:integration": "vitest run --project integration",
    "pretest:web": "node ./scripts/require-pnpm.mjs",
    "test:web": "pnpm run build && playwright test"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/react-query": "^5.99.2",
    "@tanstack/react-router": "^1.168.23",
    "@tanstack/react-router-ssr-query": "^1.166.11",
    "@tanstack/react-start": "^1.167.42",
    "@tanstack/router-plugin": "^1.167.22",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0",
    "nitro": "npm:nitro-nightly@3.0.1-20260310-183745-fc429550",
    "qrcode.react": "^4.2.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "jsdom": "^28.1.0",
    "prettier": "^3.8.3",
    "shadcn": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.58.2",
    "vite": "^7.3.2",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.4"
  }
}
