{
  "name": "frontend",
  "private": true,
  "version": "2.0.0",
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "vite dev --port 3000",
    "build": "pnpm run typecheck && vite build",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write . --ignore-path ../.prettierignore",
    "format:check": "prettier --check . --ignore-path ../.prettierignore",
    "lint": "eslint .",
    "preview": "vite preview",
    "build:workers": "pnpm run build",
    "deploy:workers": "pnpm dlx wrangler deploy",
    "deploy:workers:preview": "pnpm dlx wrangler versions upload",
    "test": "pnpm run test:unit && pnpm run test:integration && pnpm run test:web",
    "test:unit": "vitest run --project unit",
    "test:integration": "vitest run --project integration",
    "test:web": "pnpm run build && playwright test"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-router": "^1.163.3",
    "@tanstack/react-router-ssr-query": "^1.163.3",
    "@tanstack/react-start": "^1.163.3",
    "@tanstack/router-plugin": "^1.163.3",
    "lucide-react": "^0.575.0",
    "nitro": "npm:nitro-nightly@latest",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwindcss": "^4.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@playwright/test": "^1.55.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^24.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.0.4",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.3.0",
    "jsdom": "^27.0.0",
    "prettier": "^3.8.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.3.1",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.4"
  },
  "pnpm": {
    "overrides": {
      "@eslint/config-array@0.21.1>minimatch": "3.1.5",
      "@eslint/eslintrc@3.3.1>minimatch": "3.1.5",
      "eslint@9.39.2>minimatch": "3.1.5",
      "minimatch@10.1.2": "10.2.4",
      "tar@7.5.7": "7.5.8"
    }
  }
}
