# Server Configuration
server.port=8080

# DSB Mobile Credentials
dsb.username=${DSB_USERNAME}
dsb.password=${DSB_PASSWORD}

# Calendar ICS URL (Nextcloud public calendar export)
calendar.ics-url=${CALENDAR_ICS_URL}

# H2 Database Configuration
spring.datasource.url=jdbc:h2:file:./data/substitution-plans;DB_CLOSE_DELAY=-1
spring.datasource.driver-class-name=org.h2.Driver
spring.datasource.username=sa
spring.datasource.password=
spring.jpa.hibernate.ddl-auto=none
spring.jpa.show-sql=false

# Flyway migrations
spring.flyway.enabled=true
spring.flyway.locations=classpath:db/migration
spring.flyway.baseline-on-migrate=true

# Session and cookie hardening
security.session.idle-timeout=30m
server.servlet.session.timeout=${security.session.idle-timeout}
server.servlet.session.cookie.http-only=true
server.servlet.session.cookie.same-site=lax
# Keep secure in shared/staging/prod environments. Override to false only for local HTTP dev.
server.servlet.session.cookie.secure=true

# Admin bootstrap account controls (dev/local only)
security.admin.bootstrap.enabled=false
security.admin.bootstrap.username=${SECURITY_ADMIN_BOOTSTRAP_USERNAME:}
security.admin.bootstrap.password=${SECURITY_ADMIN_BOOTSTRAP_PASSWORD:}

# Strict CORS allowlist (comma-separated origins)
security.cors.allowed-origins=${SECURITY_CORS_ALLOWED_ORIGINS:}

# Actuator / health configuration
management.endpoints.web.exposure.include=health,info
