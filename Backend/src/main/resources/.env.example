# Server Configuration
SERVER_PORT=8080

# DSB Mobile Credentials
DSB_USERNAME=your_username
DSB_PASSWORD=your_password

# Calendar ICS URL (Nextcloud public calendar export)
CALENDAR_ICS_URL=https://example.test/remote.php/dav/public-calendars/your-id/?export

# H2 Database Configuration
SPRING_DATASOURCE_URL=jdbc:h2:file:./data/substitution-plans;DB_CLOSE_DELAY=-1
SPRING_DATASOURCE_DRIVER_CLASS_NAME=org.h2.Driver
SPRING_DATASOURCE_USERNAME=sa
SPRING_DATASOURCE_PASSWORD=
SPRING_JPA_HIBERNATE_DDL_AUTO=none
SPRING_JPA_SHOW_SQL=false

# Flyway
SPRING_FLYWAY_ENABLED=true
SPRING_FLYWAY_LOCATIONS=classpath:db/migration
SPRING_FLYWAY_BASELINE_ON_MIGRATE=true

# Session security
SECURITY_SESSION_IDLE_TIMEOUT=30m
SERVER_SERVLET_SESSION_COOKIE_HTTP_ONLY=true
SERVER_SERVLET_SESSION_COOKIE_SAME_SITE=lax
# Set to false only for local HTTP development
SERVER_SERVLET_SESSION_COOKIE_SECURE=true

# Optional bootstrap admin (dev/local only)
SECURITY_ADMIN_BOOTSTRAP_ENABLED=false
SECURITY_ADMIN_BOOTSTRAP_USERNAME=
SECURITY_ADMIN_BOOTSTRAP_PASSWORD=

# Comma-separated CORS allowlist origins
SECURITY_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Actuator exposure
MANAGEMENT_ENDPOINTS_WEB_EXPOSURE_INCLUDE=health,info
