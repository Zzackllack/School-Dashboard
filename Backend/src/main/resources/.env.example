# Server Configuration
SERVER_PORT=8080

# DSB Mobile Credentials
DSB_USERNAME=your_username
DSB_PASSWORD=your_password

# Calendar ICS URL (Nextcloud public calendar export)
CALENDAR_ICS_URL=https://example.test/remote.php/dav/public-calendars/your-id/?export

# H2 Database Configuration
SPRING_DATASOURCE_URL=jdbc:h2:file:./data/substitution-plans;DB_CLOSE_DELAY=-1
SPRING_DATASOURCE_DRIVER_CLASS_NAME=org.h2.Driver
SPRING_DATASOURCE_USERNAME=sa
SPRING_DATASOURCE_PASSWORD=
SPRING_JPA_HIBERNATE_DDL_AUTO=update
SPRING_JPA_SHOW_SQL=false

# Actuator / health configuration
MANAGEMENT_ENDPOINTS_WEB_EXPOSURE_INCLUDE=health,info,metrics,env

# Show health details in responses (use 'never' or secure this in production)
MANAGEMENT_ENDPOINT_HEALTH_SHOW_DETAILS=always

# Application metadata available to health/info
APP_VERSION=3.2.5

# API token for admin authentication (set this to a secure random value in production)
DISPLAY_ADMINAUTH_APITOKEN=1234